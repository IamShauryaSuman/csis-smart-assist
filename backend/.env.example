# Local LLM (Ollama)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="gemma2:2b"
EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=your-sb-secret-key
VECTOR_DIMENSIONS=1536

# Frontend integration
FRONTEND_ORIGIN="http://localhost:3000"
# Comma-separated list of allowed frontend origins (preferred)
# Example: FRONTEND_ORIGINS="http://localhost:3000,https://your-frontend.vercel.app"
FRONTEND_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
ADMIN_SEED_EMAILS="admin1@csis.edu,admin2@csis.edu"

# Google Calendar integration
GOOGLE_CALENDAR_ID="your-calendar-id@group.calendar.google.com"

# Option 1 (preferred): Set credentials via environment variables
GOOGLE_CALENDAR_REFRESH_TOKEN="your-refresh-token"
GOOGLE_CALENDAR_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CALENDAR_CLIENT_SECRET="your-client-secret"
GOOGLE_CALENDAR_TOKEN_URI="https://oauth2.googleapis.com/token"
# GOOGLE_CALENDAR_TOKEN is optional; it will be auto-refreshed via the refresh token
# GOOGLE_CALENDAR_TOKEN="your-access-token"

# Option 2 (fallback): Point to a local token JSON file
# GOOGLE_CALENDAR_TOKEN_PATH="calender/tokens.json"

# Email notifications
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_SENDER_EMAIL="no-reply@your-domain.com"
SMTP_SENDER_PASSWORD="your-app-password"
EMAIL_SENDER="no-reply@your-domain.com"
APP_PASSWORD="your-app-password"
ADMIN_RECEIVER_EMAIL="admin@your-domain.com"

# Local RAG data ingestion
RAG_LOCAL_DATA_DIR="data"
RAG_AUTO_INGEST_LOCAL_DATA=true
