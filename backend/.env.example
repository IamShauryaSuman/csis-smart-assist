# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=your-sb-secret-key
VECTOR_DIMENSIONS=768

# Frontend integration
FRONTEND_ORIGIN="http://localhost:3000"
# Comma-separated list of allowed frontend origins (preferred)
# Example: FRONTEND_ORIGINS="http://localhost:3000,https://your-frontend.vercel.app"
FRONTEND_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
ADMIN_SEED_EMAILS="admin1@csis.edu,admin2@csis.edu"

# Google APIs integration
GOOGLE_CALENDAR_ID="your-calendar-id@group.calendar.google.com"
GOOGLE_DRIVE_FOLDER_ID="your-google-drive-folder-id"

# Service account for Calendar booking writes and Drive ingestion reads (preferred)
# Share GOOGLE_CALENDAR_ID with the service account email as "Make changes to events".
# Share/allow access to GOOGLE_DRIVE_FOLDER_ID for the same service account.
# Provide either JSON payload or a path to the JSON key file.
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# GOOGLE_SERVICE_ACCOUNT_PATH="/absolute/path/to/service-account.json"
# Optional domain-wide delegation user email:
# GOOGLE_CALENDAR_SUBJECT="calendar-admin@your-domain.com"

# Option 1 (preferred): Set credentials via environment variables
GOOGLE_REFRESH_TOKEN="your-refresh-token"
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
GOOGLE_TOKEN_URI="https://oauth2.googleapis.com/token"
# GOOGLE_TOKEN is optional; it will be auto-refreshed via the refresh token
# GOOGLE_TOKEN="your-access-token"

# Option 2 (fallback): Point to a local token JSON file
# GOOGLE_TOKEN_PATH="calender/tokens.json"

# Email notifications via Gmail API (same Google OAuth app)
GOOGLE_SENDER_EMAIL="no-reply@your-domain.com"
ADMIN_RECEIVER_EMAIL="admin@your-domain.com"

# Local RAG data ingestion
RAG_LOCAL_DATA_DIR="data"
RAG_AUTO_INGEST_LOCAL_DATA=true
RAG_AUTO_INGEST_DRIVE_DATA=false

# Gemini API
GEMINI_API_KEY="your-gemini-api-key"

# SMTP Settings (Alternative to direct Google OAuth for mail)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_SENDER_EMAIL="your-email@gmail.com"
SMTP_SENDER_PASSWORD="your-app-password"
