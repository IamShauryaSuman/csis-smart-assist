# Legacy Chatbot security (unused by current backend app)
# SECRET_KEY="your-super-secret-key-change-in-production"
# ALGORITHM="HS256"
# ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Legacy Chatbot Google OAuth (unused by current backend app)
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"
# GOOGLE_REDIRECT_URI="http://localhost:8000/api/v1/auth/google/callback"

# Legacy Chatbot database (unused by current backend app)
# DATABASE_URL="sqlite:///./smartassist.db"

# Legacy generic LLM key (current backend app uses GEMINI_API_KEY)
# LLM_API_KEY="your-llm-api-key"
GEMINI_API_KEY="your-gemini-api-key"

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=your-sb-secret-key
# Legacy fallback options (only if needed):
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_KEY=your-legacy-key
VECTOR_DIMENSIONS=1536

# Frontend integration
FRONTEND_ORIGIN="http://localhost:3000"
# Comma-separated list of allowed frontend origins (preferred)
# Example: FRONTEND_ORIGINS="http://localhost:3000,https://your-frontend.vercel.app"
FRONTEND_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
ADMIN_SEED_EMAILS="admin1@csis.edu,admin2@csis.edu"

# Google Calendar integration
GOOGLE_CALENDAR_ID="your-calendar-id@group.calendar.google.com"
GOOGLE_CALENDAR_TOKEN_PATH="calender/tokens.json"

# Email notifications
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_SENDER_EMAIL="no-reply@your-domain.com"
SMTP_SENDER_PASSWORD="your-app-password"

# Local RAG data ingestion
RAG_LOCAL_DATA_DIR="data"
RAG_AUTO_INGEST_LOCAL_DATA=true
